# Sarvam AI - for Saaras (STT) and Bulbul (TTS)
SARVAM_API_KEY=your_sarvam_api_key_here

# Google Gemini - for LLM responses
GOOGLE_API_KEY=your_google_api_key_here

# Voice mode: natural (VAD, hands-free) or manual (Enter to start/stop)
# BODHI_VOICE_MODE=natural

# Optional: Input device for mic (device index or name). List devices:
# python -c "from src.audio import list_input_devices; list_input_devices()"
# BODHI_INPUT_DEVICE=0

# NeonDB PostgreSQL — permanent session/transcript storage
# Get your connection string from https://console.neon.tech
# DATABASE_URL=postgresql://user:pass@ep-xyz.us-east-2.aws.neon.tech/bodhi?sslmode=require

# Redis — local cache for sub-millisecond reads (session state, entity lookups)
# REDIS_URL=redis://localhost:6379

# Interview defaults (optional)
# BODHI_CANDIDATE=Your Name
# BODHI_COMPANY=Google
# BODHI_ROLE=Software Engineer

# FastAPI server (optional — used by uvicorn)
# BODHI_HOST=0.0.0.0
# BODHI_PORT=8000

# ── Proctoring Configuration ──────────────────────────────────────────────────

# Proctoring thresholds and intervals
FRAME_SAMPLE_INTERVAL=3
IDENTITY_REVERIFY_INTERVAL=30
FACE_SIMILARITY_THRESHOLD=0.28
GAZE_DEVIATION_THRESHOLD=30.0
VIOLATION_AUTO_FLAG_COUNT=5

# CV model configuration
FACE_RECOGNITION_MODEL=Facenet512
OBJECT_DETECTION_CONFIDENCE=0.5
YOLO_MODEL_VARIANT=yolov8n

# Debug mode (shows detailed analysis in responses)
DEBUG=false

# MongoDB (optional - for proctoring data persistence)
# MONGODB_URL=mongodb://localhost:27017
# MONGODB_DB_NAME=proctoring_db

# AWS S3 (optional - for snapshot storage)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=proctoring-snapshots

